<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_gradient"
    android:padding="24dp"
    tools:context=".SpecialAccessActivity">

    <TextView
        android:id="@+id/specialSubtitleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/special_subtitle"
        android:textColor="@color/accent_secondary"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonClose"
        android:layout_width="wrap_content"
        android:layout_height="42dp"
        android:background="@drawable/bg_secondary_button"
        android:minWidth="0dp"
        android:paddingHorizontal="14dp"
        android:text="@string/special_close"
        android:textAllCaps="false"
        android:textColor="@color/text_primary"
        app:icon="@drawable/ic_logout"
        app:iconGravity="textStart"
        app:iconPadding="6dp"
        app:iconSize="16dp"
        app:iconTint="@color/text_primary"
        app:layout_constraintBottom_toBottomOf="@id/specialSubtitleText"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/specialSubtitleText" />

    <TextView
        android:id="@+id/specialTitleText"
        style="@style/TextAppearance.GietErp.HeroTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/special_title"
        android:textSize="28sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/specialSubtitleText" />

    <TextView
        android:id="@+id/specialDescriptionText"
        style="@style/TextAppearance.GietErp.BodySecondary"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/special_description"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/specialTitleText" />

    <TextView
        android:id="@+id/programFixedText"
        style="@style/TextAppearance.GietErp.BodySecondary"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="6dp"
        android:background="@drawable/bg_stat_card"
        android:gravity="center"
        android:padding="12dp"
        android:text="@string/special_program_fixed"
        android:textColor="@color/text_primary"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@id/programIdFixedText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/specialDescriptionText"
        app:layout_constraintWidth_percent="0.48" />

    <TextView
        android:id="@+id/programIdFixedText"
        style="@style/TextAppearance.GietErp.BodySecondary"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="6dp"
        android:background="@drawable/bg_stat_card"
        android:gravity="center"
        android:padding="12dp"
        android:text="@string/special_program_id_fixed"
        android:textColor="@color/text_primary"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/programFixedText"
        app:layout_constraintTop_toTopOf="@id/programFixedText"
        app:layout_constraintWidth_percent="0.48" />

    <TextView
        android:id="@+id/branchLabelText"
        style="@style/TextAppearance.GietErp.BodySecondary"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="@string/special_branch_label"
        android:textColor="@color/text_primary"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/programFixedText" />

    <Spinner
        android:id="@+id/branchSpinner"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_input_field"
        android:paddingHorizontal="12dp"
        android:popupBackground="@color/surface_card_strong"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/branchLabelText" />

    <TextView
        android:id="@+id/semesterLabelText"
        style="@style/TextAppearance.GietErp.BodySecondary"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/special_semester_label"
        android:textColor="@color/text_primary"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/branchSpinner" />

    <Spinner
        android:id="@+id/semesterSpinner"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_input_field"
        android:paddingHorizontal="12dp"
        android:popupBackground="@color/surface_card_strong"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/semesterLabelText" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/openResultsButton"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginTop="18dp"
        android:background="@drawable/bg_primary_button"
        android:text="@string/special_open_results"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/semesterSpinner" />

    <TextView
        android:id="@+id/specialHintText"
        style="@style/TextAppearance.GietErp.BodySecondary"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:gravity="center"
        android:text="@string/special_search_hint"
        android:textColor="@color/text_secondary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/openResultsButton" />

    <LinearLayout
        android:id="@+id/infoCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_glass_card"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/specialHintText">

        <TextView
            style="@style/TextAppearance.GietErp.BodySecondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/special_form_hint"
            android:textColor="@color/text_secondary"
            tools:text="@string/special_form_hint" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
