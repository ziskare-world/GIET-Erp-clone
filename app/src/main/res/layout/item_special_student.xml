<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_stat_card"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:id="@+id/studentNameText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/text_primary"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/rollNoText"
        style="@style/TextAppearance.GietErp.BodySecondary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="@color/text_primary" />

    <TextView
        android:id="@+id/registrationNoText"
        style="@style/TextAppearance.GietErp.BodySecondary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp" />

    <TextView
        android:id="@+id/programBranchText"
        style="@style/TextAppearance.GietErp.BodySecondary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp" />

    <TextView
        android:id="@+id/semesterSectionText"
        style="@style/TextAppearance.GietErp.BodySecondary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp" />

    <TextView
        android:id="@+id/contactText"
        style="@style/TextAppearance.GietErp.BodySecondary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp" />

    <TextView
        android:id="@+id/hostelInfoText"
        style="@style/TextAppearance.GietErp.BodySecondary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp" />

    <TextView
        style="@style/TextAppearance.GietErp.BodySecondary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/special_tap_to_view_details"
        android:textColor="@color/accent_secondary"
        android:textStyle="bold" />

</LinearLayout>
