<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_gradient"
    android:padding="24dp"
    tools:context=".SpecialSearchResultsActivity">

    <TextView
        android:id="@+id/resultsSubtitleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/special_subtitle"
        android:textColor="@color/accent_secondary"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonBack"
        android:layout_width="wrap_content"
        android:layout_height="42dp"
        android:background="@drawable/bg_secondary_button"
        android:minWidth="0dp"
        android:paddingHorizontal="14dp"
        android:text="@string/special_back"
        android:textAllCaps="false"
        android:textColor="@color/text_primary"
        app:icon="@drawable/ic_back"
        app:iconGravity="textStart"
        app:iconPadding="6dp"
        app:iconSize="16dp"
        app:iconTint="@color/text_primary"
        app:layout_constraintBottom_toBottomOf="@id/resultsSubtitleText"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/resultsSubtitleText" />

    <TextView
        android:id="@+id/resultsTitleText"
        style="@style/TextAppearance.GietErp.HeroTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/special_results_title"
        android:textSize="28sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/resultsSubtitleText" />

    <LinearLayout
        android:id="@+id/summaryRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:baselineAligned="false"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/resultsTitleText">

        <TextView
            android:id="@+id/branchSummaryText"
            style="@style/TextAppearance.GietErp.BodySecondary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_stat_card"
            android:gravity="center"
            android:padding="12dp"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            tools:text="Branch: All Branches" />

        <TextView
            android:id="@+id/semesterSummaryText"
            style="@style/TextAppearance.GietErp.BodySecondary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/bg_stat_card"
            android:gravity="center"
            android:padding="12dp"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            tools:text="Semester: 6" />
    </LinearLayout>

    <EditText
        android:id="@+id/rollNoInput"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_input_field"
        android:hint="@string/special_roll_hint"
        android:inputType="text"
        android:paddingHorizontal="14dp"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_secondary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/summaryRow" />

    <EditText
        android:id="@+id/nameInput"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_input_field"
        android:hint="@string/special_name_hint"
        android:inputType="textCapWords"
        android:paddingHorizontal="14dp"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_secondary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/rollNoInput" />

    <TextView
        android:id="@+id/resultsCountText"
        style="@style/TextAppearance.GietErp.BodySecondary"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/special_results_initial"
        android:textColor="@color/text_primary"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/nameInput"
        tools:text="0 students" />

    <FrameLayout
        android:id="@+id/listCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_glass_card"
        android:padding="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/resultsCountText">

        <ListView
            android:id="@+id/studentListView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:divider="@android:color/transparent"
            android:dividerHeight="8dp"
            android:fastScrollEnabled="true"
            android:padding="2dp"
            tools:listitem="@layout/item_special_student" />

        <TextView
            android:id="@+id/emptyStateText"
            style="@style/TextAppearance.GietErp.BodySecondary"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="@string/special_no_data"
            android:textColor="@color/text_secondary"
            android:visibility="gone" />

        <FrameLayout
            android:id="@+id/loadingOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/loading_scrim"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:background="@drawable/bg_loader_card"
                android:elevation="8dp"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingHorizontal="24dp"
                android:paddingVertical="20dp">

                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:indeterminate="true"
                    app:indicatorColor="@color/accent_secondary"
                    app:trackColor="@color/stroke_soft"
                    app:trackThickness="4dp" />

                <TextView
                    style="@style/TextAppearance.GietErp.BodySecondary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/special_loading"
                    android:textColor="@color/text_primary" />
            </LinearLayout>
        </FrameLayout>
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
