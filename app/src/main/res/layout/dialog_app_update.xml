<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp">

    <ImageView
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_gravity="center_horizontal"
        android:contentDescription="@string/app_name"
        android:src="@drawable/download" />

    <TextView
        android:id="@+id/updateTitle"
        style="@style/TextAppearance.GietErp.ScreenTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:text="@string/update_available_title" />

    <TextView
        android:id="@+id/updateMessage"
        style="@style/TextAppearance.GietErp.BodyPrimary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center_horizontal"
        android:text="@string/update_available_message"
        android:textAlignment="center" />

    <TextView
        android:id="@+id/updateStatusText"
        style="@style/TextAppearance.GietErp.BodySecondary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center_horizontal"
        android:text="@string/update_status_preparing_download"
        android:textAlignment="center" />

    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/updateProgressBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:visibility="gone"
        app:indicatorColor="@color/accent_secondary"
        app:trackColor="@color/stroke_soft" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:gravity="end"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/updateSecondaryButton"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/bg_secondary_button"
            android:text="@string/update_action_later"
            android:textAllCaps="false"
            android:textColor="@color/text_primary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/updatePrimaryButton"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:background="@drawable/bg_primary_button"
            android:text="@string/update_action_now"
            android:textAllCaps="false"
            android:textColor="@color/white" />
    </LinearLayout>

</LinearLayout>
