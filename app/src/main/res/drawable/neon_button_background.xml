<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Pressed state -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#0D47A1" /> <!-- Dark blue when pressed -->
            <stroke android:width="3dp" android:color="#33CCFF" />
            <corners android:radius="12dp" />
            <padding android:top="10dp" android:bottom="10dp" android:left="10dp" android:right="10dp" />
        </shape>
    </item>

    <!-- Default state -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#3C1561E6" /> <!-- Bright blue -->
            <stroke android:width="3dp" android:color="#33FF41" /> <!-- Neon border -->
            <corners android:radius="12dp" />
            <padding android:top="10dp" android:bottom="10dp" android:left="10dp" android:right="10dp" />
            <gradient
                android:startColor="#1E88E5"
                android:centerColor="#1561E6"
                android:endColor="#0D47A1"
                android:angle="270" />
        </shape>
    </item>
</selector>
